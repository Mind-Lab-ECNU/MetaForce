# Required: source data root (read-only inputs are loaded from here)
DATA_ROOT=/inspire/hdd/project/ai4education/public/wsa_1.0/verltools/verl_m/data_multi_category/data

# Optional: all generated artifacts are written under OUTPUT_BASE_DIR
# Default: DATA_ROOT
OUTPUT_BASE_DIR=/inspire/hdd/project/ai4education/public/wsa_1.0/verltools/verl_m/data_multi_category/data

# Optional: configurable merge folder names
TRAIN_MERGE_DIR_NAME=train_merge_final_tool_id
TEST_MERGE_DIR_NAME=test_merge_final_tool_id

# Optional: tool json paths for prompt update
# Defaults:
#   scripts_v2/train/real_tool.json
#   scripts_v2/test/real_tool.json
# You can also point both variables to *_tool_all.json or *_tool_all.json
# when generating the corresponding experiment variant.
TRAIN_TOOL_JSON=/inspire/hdd/project/ai4education/public/wsa_1.0/verltools/verl_m/data_multi_category/scripts_v2/train/real_tool_id.json
TEST_TOOL_JSON=/inspire/hdd/project/ai4education/public/wsa_1.0/verltools/verl_m/data_multi_category/scripts_v2/test/real_tool_id.json

# Optional: final merged json outputs (parquet paths are auto-derived)
# Defaults are under OUTPUT_BASE_DIR/<*_MERGE_DIR_NAME>/
# Important:
# - OUT_TEST_ALL_JSON / OUT_TEST_ID_JSON / OUT_TEST_OOD_JSON refer to dataset splits:
#   - ALL = merged(ID datasets + OOD datasets)
#   - ID = only ID datasets
#   - OOD = only OOD datasets
# - These names do NOT mean tool variants.
# - Tool variants are controlled separately by TRAIN_TOOL_JSON / TEST_TOOL_JSON
#   and by which runtime tool server script you choose at train/eval time.
OUT_TRAIN_JSON=/inspire/hdd/project/ai4education/public/wsa_1.0/verltools/verl_m/data_multi_category/data/train_merge_final_tool_id/train_merge_final_tool_id.json
OUT_TEST_ALL_JSON=/inspire/hdd/project/ai4education/public/wsa_1.0/verltools/verl_m/data_multi_category/data/test_merge_final_tool_id/test_merge_final_tool_id.json
OUT_TEST_ID_JSON=/inspire/hdd/project/ai4education/public/wsa_1.0/verltools/verl_m/data_multi_category/data/test_merge_final_tool_id/test_id_merge_final_tool_id.json
OUT_TEST_OOD_JSON=/inspire/hdd/project/ai4education/public/wsa_1.0/verltools/verl_m/data_multi_category/data/test_merge_final_tool_id/test_ood_merge_final_tool_id.json

# Optional sampling and strict flags
SEED=42
# Default sample for most train datasets
TRAIN_SAMPLE=500
# MapQA train sample; adjust this value when needed
MAPQA_TRAIN_SAMPLE=500
# CLEVR_MATH train sample per subset (addition/subtraction/subtraction_multihop/adversarial)
CLEVR_MATH_TRAIN_SAMPLE_PER_SUBSET=150
THRESHOLD=5000
SAMPLE_OVER_THRESHOLD=2000
SAMPLE_PER_SUBSET=500

# STRICT can be: 1/0, true/false, yes/no, on/off
STRICT=1

# Optional: which stages to run — train / test / all (default: all)
RUN_STAGES=train
