# Required: source data root (read-only inputs are loaded from here)
DATA_ROOT=/inspire/hdd/project/ai4education/public/wsa_1.0/verltools/verl_m/data_multi_category/data

# Optional: all generated artifacts are written under OUTPUT_BASE_DIR
# Default: DATA_ROOT
OUTPUT_BASE_DIR=/inspire/hdd/project/ai4education/public/wsa_1.0/verltools/verl_m/data_multi_category/data

# Optional: configurable merge folder name
TEST_MERGE_DIR_NAME=test_merge_v3_ai2d_mathvista_tool_id

# Optional: tool json path for prompt update
# Defaults:
#   scripts_v3/test/real_tool.json
# You can also point this variable to *_tool_id.json or *_tool_ood.json
# when generating the corresponding experiment variant.
TEST_TOOL_JSON=/inspire/hdd/project/ai4education/public/wsa_1.0/verltools/verl_m/data_multi_category/scripts_v3/test/real_tool_id.json

# Optional: final merged json output (parquet path is auto-derived)
# Default is under OUTPUT_BASE_DIR/<TEST_MERGE_DIR_NAME>/
OUT_TEST_OOD_JSON=/inspire/hdd/project/ai4education/public/wsa_1.0/verltools/verl_m/data_multi_category/data/test_merge_v3_ai2d_mathvista_tool_id/test_ood_merge_v3_ai2d_mathvista_tool_id.json

# Optional sampling and strict flags
SEED=42
THRESHOLD=5000
SAMPLE_OVER_THRESHOLD=2000

# STRICT can be: 1/0, true/false, yes/no, on/off
STRICT=1
