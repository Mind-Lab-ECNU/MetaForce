# Required: source data root (read-only inputs are loaded from here)
DATA_ROOT=/inspire/hdd/project/ai4education/public/wsa_1.0/verltools/verl_m/data_multi_category/data

# Optional: output directory for generated test.json / test.parquet
# Default: DATA_ROOT
OUTPUT_BASE_DIR=/inspire/hdd/project/ai4education/public/wsa_1.0/verltools/verl_m/data_multi_category/data

# Optional: MapQA source location under DATA_ROOT
SRC_REL_DIR=geospatial/MapQA_2000
SRC_FILE=test.json

# Optional: final output folder name under OUTPUT_BASE_DIR
# You can rename this freely for different experiments.
OUTPUT_NAME=MapQA_test_ID_tool_id

# Optional: dataset label written into each record.
# Keep this aligned with scripts_v2 MapQA by default.
DATA_SOURCE=MapQA_test_ID

# Optional: final output file names inside OUTPUT_NAME/
OUT_JSON_NAME=test_tool_id.json
OUT_PARQUET_NAME=test_tool_id.parquet

# Optional: tool json path for prompt update
# Default: script_mapqa/../scripts_v2/test/real_tool.json
TOOL_JSON=/inspire/hdd/project/ai4education/public/wsa_1.0/verltools/verl_m/data_multi_category/scripts_v2/test/real_tool_id.json

# STRICT can be: 1/0, true/false, yes/no, on/off
STRICT=1
